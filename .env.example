# Copy to .env (gitignored) and fill in. Sourced by bin/sync-from-bluehost.sh.
# .env stays local — never commit it.

# SSH target for the daily WordPress dump
REMOTE_USER="your-host-user"
REMOTE_HOST="your-host.example.com"
REMOTE_WP_DIR="public_html"   # path under $HOME on the remote
SSH_KEY="$HOME/.ssh/id_ed25519_bluehost"

# Backup retention (days)
KEEP_DAYS=7
